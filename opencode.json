{
    "$schema": "https://opencode.ai/config.json",
    "permission": {
        "bash": {
            "*": "ask",
            "git *": "allow",
            "npm *": "allow",
            "rm *": "deny",
            "grep *": "allow"
        },
        "edit": {
            "*": "deny",
            "packages/web/src/content/docs/*.mdx": "allow"
        }
 },
    "mcp": {
        "laravel-boost": {
            "type": "local",
            "enabled": true,
            "command": [
                "wsl.exe",
                "/usr/bin/php8.4",
                "/mnt/c/sites/pubblicittadev/artisan",
                "boost:mcp"
            ]
        }
    },
    "provider": {
        "ollama": {
            "npm": "@ai-sdk/openai-compatible",
            "name": "Ollama",
            "options": {
                "baseURL": "http://127.0.0.1:11434"
            },
            "models": {
                "gemma4:e2b": {
                    "name": "gemma4:e2b"
                },
                "qwen3.5:9b": {
                    "name": "qwen3.5:9b"
                }
            }
        }
    }
}
